<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>To My Forever Love 💍 Will You Say Yes Again?</title>
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Great+Vibes&family=Poppins:wght@400;600&display=swap"/>
  <script src="https://cdn.jsdelivr.net/npm/canvas-confetti@1.9.3/dist/confetti.browser.min.js"></script>
  <style>
    * { margin:0; padding:0; box-sizing:border-box; }
    body {
      font-family: 'Poppins', sans-serif;
      background: linear-gradient(to bottom, #ff9a9e, #fad0c4);
      color: #333;
      min-height: 100vh;
      position: relative;
      overflow-x: hidden;
    }
    h1, h2 { font-family: 'Great Vibes', cursive; color: #c2185b; text-align: center; margin: 20px 0; }
    section { padding: 50px 15px; max-width: 1000px; margin: auto; }
    .hearts { position: fixed; inset: 0; pointer-events: none; z-index: -1; overflow: hidden; }
    .heart {
      position: absolute; font-size: 24px; animation: float 10s linear infinite;
      opacity: 0.8; user-select: none;
    }
    @keyframes float {
      0% { transform: translateY(110vh) rotate(0deg); }
      100% { transform: translateY(-20vh) rotate(1080deg); }
    }
    .intro { text-align: center; padding-top: 60px; }
    .games { background: rgba(255,255,255,0.4); border-radius: 20px; padding: 30px; margin: 30px auto; }
    .game { margin: 40px 0; border: 1px solid #ffb3c6; border-radius: 16px; padding: 20px; background: white; }
    .game h3 { color: #d81b60; margin-bottom: 15px; }
    #tic-board { display: grid; grid-template-columns: repeat(3, 80px); gap: 8px; justify-content: center; margin: 20px auto; }
    .tic-cell { width: 80px; height: 80px; background: #fff0f5; border: 2px solid #ff80ab; font-size: 3rem; display: flex; align-items: center; justify-content: center; cursor: pointer; }
    .tic-cell:hover { background: #ffe4e1; }
    #rps-buttons { text-align: center; margin: 20px 0; }
    .rps-btn { font-size: 4rem; margin: 0 20px; cursor: pointer; background: none; border: none; transition: transform 0.2s; }
    .rps-btn:hover { transform: scale(1.3); }
    #memory-grid { display: grid; grid-template-columns: repeat(4, 70px); gap: 10px; justify-content: center; margin: 20px auto; }
    .memory-card { width: 70px; height: 90px; perspective: 1000px; cursor: pointer; }
    .memory-inner { position: relative; width: 100%; height: 100%; transition: transform 0.6s; transform-style: preserve-3d; }
    .memory-card.flipped .memory-inner { transform: rotateY(180deg); }
    .memory-front, .memory-back {
      position: absolute; inset: 0; backface-visibility: hidden; display: flex; align-items: center; justify-content: center;
      font-size: 2.5rem; border-radius: 12px; background: #ff80ab; color: white;
    }
    .memory-back { background: #ffb3c6; transform: rotateY(180deg); }
    .quiz-question { margin: 25px 0; font-size: 1.2rem; }
    .quiz-options button { display: block; margin: 10px auto; padding: 12px 30px; font-size: 1.1rem; cursor: pointer; }
    #snake-board { width: 300px; height: 300px; background: #fff0f5; margin: 20px auto; position: relative; border: 2px solid #ff4081; overflow: hidden; }
    .snake-part { position: absolute; width: 20px; height: 20px; background: #d81b60; border-radius: 4px; }
    .food { position: absolute; width: 20px; height: 20px; background: #ffeb3b; border-radius: 50%; }
    .proposal { background: rgba(255,255,255,0.85); border-radius: 24px; padding: 50px 30px; text-align: center; box-shadow: 0 10px 40px rgba(216,27,96,0.3); }
    .letter { font-size: 1.25rem; line-height: 1.8; max-width: 720px; margin: 30px auto; }
    .yes-btn {
      margin-top: 40px; padding: 18px 70px; font-size: 2.4rem; font-weight: bold;
      background: #ff4081; color: white; border: none; border-radius: 60px; cursor: pointer;
      box-shadow: 0 8px 30px rgba(255,64,129,0.5); transition: all 0.3s;
    }
    .yes-btn:hover { transform: scale(1.12); background: #f50057; }
  </style>
</head>
<body>

<div class="hearts" id="hearts"></div>

<section class="intro">
  <h1>Hey My Love 💕</h1>
  <p style="font-size:1.5rem; margin:25px 0;">I fall for you more every day… so I want to ask again…</p>
  <h2 style="font-size:3.8rem;">Will you be mine forever? ✨💍</h2>
</section>

<section class="games">
  <h2 style="font-size:2.6rem;">🎮 Play These Games… Then Read My Letter</h2>

  <!-- 1. Tic Tac Toe -->
  <div class="game">
    <h3>1. Tic Tac Toe (You = ❤️  Me = ⭐)</h3>
    <div id="tic-board"></div>
    <p id="tic-status" style="text-align:center; font-size:1.3rem; margin-top:15px;">Your turn ❤️</p>
  </div>

  <!-- 2. Rock Paper Scissors -->
  <div class="game">
    <h3>2. Rock Paper Scissors</h3>
    <div id="rps-buttons">
      <button class="rps-btn" onclick="rpsPlay('🪨')">🪨</button>
      <button class="rps-btn" onclick="rpsPlay('📄')">📄</button>
      <button class="rps-btn" onclick="rpsPlay('✂️')">✂️</button>
    </div>
    <p id="rps-result" style="text-align:center; font-size:1.4rem;"></p>
  </div>

  <!-- 3. Memory Game -->
  <div class="game">
    <h3>3. Memory – Match the Hearts</h3>
    <div id="memory-grid"></div>
    <p id="memory-status" style="text-align:center; font-size:1.3rem; margin-top:15px;">Pairs found: 0 / 6</p>
  </div>

  <!-- 4. Love Quiz -->
  <div class="game">
    <h3>4. Our Love Quiz</h3>
    <div id="quiz-container">
      <div class="quiz-question" id="quiz-question"></div>
      <div id="quiz-options"></div>
      <p id="quiz-feedback" style="font-size:1.3rem; margin:15px 0; text-align:center;"></p>
    </div>
  </div>

  <!-- 5. Snake -->
  <div class="game">
    <h3>5. Snake – Collect Hearts!</h3>
    <div id="snake-board"></div>
    <p style="text-align:center; font-size:1.3rem; margin-top:15px;">Use arrow keys • Score: <span id="snake-score">0</span></p>
  </div>
</section>

<section class="proposal">
  <h1>💌 My Re-Proposal Letter</h1>
  <div class="letter">
    <p>My dearest [Her Name],</p>
    <p>Every laugh, every late-night talk, every small fight we fix… makes me love you even more than yesterday.</p>
    <p>I still smile thinking about [put one memory here – example: our first long drive when we sang badly together]. Moments like that remind me you're my home.</p>
    <p>So today I want to ask again — with my whole heart:</p>
    <p style="font-size:1.9rem; margin:40px 0; color:#d81b60; font-weight:bold;">
      Will you keep saying yes to us… every single day… forever? 💍❤️
    </p>
  </div>
  <button class="yes-btn" onclick="sayYes()">YES, FOREVER! 💕</button>
</section>

<script>
// Floating hearts
const heartsDiv = document.getElementById('hearts');
const heartEmojis = ['❤️','💖','💗','💓','💞','💘','💝'];
function spawnHeart() {
  const h = document.createElement('div');
  h.className = 'heart';
  h.textContent = heartEmojis[Math.floor(Math.random()*heartEmojis.length)];
  h.style.left = Math.random()*100 + 'vw';
  h.style.animationDuration = (Math.random()*6 + 8) + 's';
  h.style.fontSize = (Math.random()*18 + 16) + 'px';
  heartsDiv.appendChild(h);
  setTimeout(() => h.remove(), 14000);
}
setInterval(spawnHeart, 350);

// Tic Tac Toe
const ticBoard = document.getElementById('tic-board');
const ticStatus = document.getElementById('tic-status');
let ticCells = [], ticCurrent = '❤️', ticGameActive = true;
for(let i=0; i<9; i++){
  const cell = document.createElement('div');
  cell.className = 'tic-cell';
  cell.onclick = () => ticClick(i);
  ticBoard.appendChild(cell);
  ticCells.push('');
}
function ticClick(idx){
  if(!ticGameActive || ticCells[idx]) return;
  ticCells[idx] = ticCurrent;
  ticBoard.children[idx].textContent = ticCurrent;
  if(ticCheckWin()) {
    ticStatus.textContent = ticCurrent + ' wins! 🎉';
    ticGameActive = false;
    return;
  }
  if(ticCells.every(c=>c)) {
    ticStatus.textContent = "It's a tie!";
    ticGameActive = false;
    return;
  }
  ticCurrent = ticCurrent==='❤️' ? '⭐' : '❤️';
  ticStatus.textContent = ticCurrent + "'s turn";
}
function ticCheckWin(){
  const wins = [[0,1,2],[3,4,5],[6,7,8],[0,3,6],[1,4,7],[2,5,8],[0,4,8],[2,4,6]];
  return wins.some(combo => combo.every(i => ticCells[i]===ticCurrent));
}

// Rock Paper Scissors
function rpsPlay(player){
  const choices = ['🪨','📄','✂️'];
  const comp = choices[Math.floor(Math.random()*3)];
  let msg = `You: ${player}  •  Me: ${comp}<br>`;
  if(player === comp) msg += "Tie!";
  else if(
    (player==='🪨' && comp==='✂️') ||
    (player==='📄' && comp==='🪨') ||
    (player==='✂️' && comp==='📄')
  ) msg += "You win this round! 😍";
  else msg += "I win! Better luck next time 😉";
  document.getElementById('rps-result').innerHTML = msg;
}

// Memory Game
const memoryGrid = document.getElementById('memory-grid');
const memoryStatus = document.getElementById('memory-status');
let memoryCards = ['❤️','❤️','💖','💖','💗','💗','💓','💓','💞','💞','💘','💘'];
memoryCards.sort(()=>Math.random()-0.5);
let memoryFlipped = [], memoryFound = 0;
memoryCards.forEach((val, i) => {
  const card = document.createElement('div');
  card.className = 'memory-card';
  card.innerHTML = `<div class="memory-inner">
    <div class="memory-front">${val}</div>
    <div class="memory-back">?</div>
  </div>`;
  card.onclick = () => memoryFlip(card, val);
  memoryGrid.appendChild(card);
});
function memoryFlip(card, val){
  if(card.classList.contains('flipped') || memoryFlipped.length === 2) return;
  card.classList.add('flipped');
  memoryFlipped.push({card, val});
  if(memoryFlipped.length === 2){
    setTimeout(() => {
      if(memoryFlipped[0].val === memoryFlipped[1].val){
        memoryFound++;
        memoryStatus.textContent = `Pairs found: ${memoryFound} / 6`;
        if(memoryFound === 6) memoryStatus.textContent += " – You won my heart again! 💕";
      } else {
        memoryFlipped.forEach(c => c.card.classList.remove('flipped'));
      }
      memoryFlipped = [];
    }, 900);
  }
}

// Quiz
const quizData = [
  { q: "What was our first date food?", a: "Pizza", opts: ["Pizza","Burger","Pasta","Ice cream"] },
  { q: "My favorite thing about you is your…", a: "Smile", opts: ["Smile","Eyes","Laugh","Hugs"] },
  { q: "Our song is…", a: "Something romantic", opts: ["Something romantic","Party song","Sad song","No song"] },
  { q: "I love you…", a: "More than anything", opts: ["More than anything","A lot","Little bit","Yesterday only"] },
  { q: "Will you say yes again?", a: "Yes!", opts: ["Yes!","Maybe","No","Ask later"] }
];
let quizIdx = 0;
function loadQuiz(){
  const q = quizData[quizIdx];
  document.getElementById('quiz-question').textContent = q.q;
  const optsDiv = document.getElementById('quiz-options');
  optsDiv.innerHTML = '';
  q.opts.forEach(opt => {
    const btn = document.createElement('button');
    btn.textContent = opt;
    btn.onclick = () => quizAnswer(opt);
    optsDiv.appendChild(btn);
  });
}
function quizAnswer(selected){
  const correct = quizData[quizIdx].a;
  const fb = document.getElementById('quiz-feedback');
  fb.textContent = selected === correct ? "Correct! ❤️" : `Wrong… it was ${correct}`;
  quizIdx++;
  if(quizIdx < quizData.length) setTimeout(loadQuiz, 1400);
  else fb.textContent += " Quiz done! Now read the letter below ↓";
}
loadQuiz();

// Snake (very basic)
const snakeBoard = document.getElementById('snake-board');
let snake = [{x:140, y:140}], dir = {x:20, y:0}, food, scoreEl = document.getElementById('snake-score'), score=0;
function placeFood(){
  food = {x: Math.floor(Math.random()*14)*20 + 20, y: Math.floor(Math.random()*14)*20 + 20};
  let f = document.createElement('div');
  f.className = 'food'; f.style.left = food.x+'px'; f.style.top = food.y+'px';
  snakeBoard.appendChild(f);
}
placeFood();
function snakeUpdate(){
  let head = {x: snake[0].x + dir.x, y: snake[0].y + dir.y};
  if(head.x<0||head.x>=300||head.y<0||head.y>=300||snake.some(s=>s.x===head.x&&s.y===head.y)){
    alert("Game over! Score: " + score); location.reload(); return;
  }
  snake.unshift(head);
  if(head.x===food.x && head.y===food.y){
    score++; scoreEl.textContent = score; snakeBoard.lastChild.remove(); placeFood();
  } else snake.pop();
  snakeBoard.innerHTML = ''; snake.forEach(s=>{
    let p = document.createElement('div'); p.className='snake-part';
    p.style.left=s.x+'px'; p.style.top=s.y+'px'; snakeBoard.appendChild(p);
  });
  snakeBoard.appendChild(snakeBoard.lastChild); // keep food
}
setInterval(snakeUpdate, 180);
document.addEventListener('keydown', e=>{
  if(e.key==='ArrowUp' && dir.y===0) dir={x:0,y:-20};
  if(e.key==='ArrowDown' && dir.y===0) dir={x:0,y:20};
  if(e.key==='ArrowLeft' && dir.x===0) dir={x:-20,y:0};
  if(e.key==='ArrowRight' && dir.x===0) dir={x:20,y:0};
});

// Yes button
function sayYes(){
  confetti({ particleCount: 300, spread: 100, origin: {y:0.6} });
  setTimeout(()=>alert("She said YES!!! 🎉💍 I love you forever! ❤️"), 600);
}
</script>

</body>
</html>
